# =============================================================================
# Terraform Variables Example
#
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
#
# Required variables (no defaults):
#   - key_pair_name: Your AWS SSH key pair name
#   - db_password:   MySQL database password
# =============================================================================

# AWS region (default: ap-southeast-1 / Singapore)
# aws_region = "ap-southeast-1"

# EC2 instance type (default: t3.small)
# instance_type = "t3.small"

# Your AWS SSH key pair name (REQUIRED)
key_pair_name = "my-ssh-key"

# MySQL database password (REQUIRED)
db_password = "change-me-to-a-strong-password"

# CIDR blocks allowed to SSH (default: open to all - restrict in production!)
# ssh_allowed_cidr = ["YOUR_IP/32"]

# GitHub repository URL (default: adi3246/allsome-orders-analytics)
# github_repo_url = "https://github.com/adi3246/allsome-orders-analytics.git"
